{
   "name": "jv2w/betterpmmp",
   "description": "A maintained continuation of PocketMine-MP, a server software for Minecraft: Bedrock Edition written in PHP",
   "type": "project",
   "homepage": "https://github.com/jv2w/BetterPMMP",
   "license": "LGPL-3.0-or-later",
   "require": {
      "php": "^8.1",
      "php-64bit": "*",
      "ext-chunkutils2": "^0.3.1",
      "ext-crypto": "^0.3.1",
      "ext-ctype": "*",
      "ext-curl": "*",
      "ext-date": "*",
      "ext-encoding": "~1.0.0",
      "ext-gmp": "*",
      "ext-hash": "*",
      "ext-igbinary": "^3.0.1",
      "ext-json": "*",
      "ext-leveldb": "^0.2.1 || ^0.3.0",
      "ext-mbstring": "*",
      "ext-morton": "^0.1.0",
      "ext-openssl": "*",
      "ext-pcre": "*",
      "ext-phar": "*",
      "ext-pmmpthread": "^6.1.0",
      "ext-reflection": "*",
      "ext-simplexml": "*",
      "ext-sockets": "*",
      "ext-spl": "*",
      "ext-yaml": ">=2.0.0",
      "ext-zip": "*",
      "ext-zlib": ">=1.2.11",
      "composer-runtime-api": "^2.0",
      "adhocore/json-comment": "~1.2.0",
      "netresearch/jsonmapper": "~v5.0.0",
      "pocketmine/bedrock-block-upgrade-schema": "~5.2.0+bedrock-1.21.110",
      "pocketmine/bedrock-data": "~6.7.0+bedrock-1.26.30",
      "pocketmine/bedrock-item-upgrade-schema": "~1.17.0+bedrock-1.26.20",
      "pocketmine/bedrock-protocol": "~58.0.0+bedrock-1.26.30",
      "pocketmine/binaryutils": "^0.2.1",
      "pocketmine/callback-validator": "~1.0.4",
      "pocketmine/color": "^0.3.0",
      "pocketmine/errorhandler": "^0.7.0",
      "pocketmine/log": "^0.4.0",
      "pocketmine/math": "~1.0.0",
      "pocketmine/nbt": "~1.2.0",
      "pocketmine/raklib": "~1.2.0",
      "pocketmine/raklib-ipc": "~1.0.0",
      "pocketmine/snooze": "^0.5.0",
      "ramsey/uuid": "~4.9.0",
      "symfony/filesystem": "~6.4.0"
   },
   "require-dev": {
      "phpstan/phpstan": "2.1.46",
      "phpstan/phpstan-phpunit": "^2.0.0",
      "phpstan/phpstan-strict-rules": "^2.0.0",
      "phpunit/phpunit": "^10.5.24"
   },
   "suggest": {
      "ext-snappy": "Required by better-pmmp.network.snappy-compression; without it the server logs a warning and falls back to zlib"
   },
   "replace": {
      "symfony/polyfill-ctype": "*",
      "symfony/polyfill-mbstring": "*"
   },
   "autoload": {
      "psr-4": {
         "pocketmine\\": [
            "src/",
            "generated/"
         ]
      },
      "files": [
         "src/CoreConstants.php"
      ]
   },
   "autoload-dev": {
      "psr-4": {
         "pocketmine\\": "tests/phpunit/"
      }
   },
   "config": {
      "platform": {
         "php": "8.1.0"
      },
      "sort-packages": true
   },
   "extra": {
      "betterpmmp-vendor-patches": {
         "_comment": "BetterPMMP modifies these vendor files in place, and the patched versions are what this repository commits. Composer owns vendor/, so an install or update silently reverts them; restore with 'git checkout -- <file>'. The .patch files record the change for review and for trees that are not checkouts - they are already applied here, so 'git apply' on a fresh clone will report that the patch does not apply. Each patched file carries a [BetterPMMP-PATCH] marker, so grep for it to check.",
         "vendor/pocketmine/raklib/src/server/Server.php": "build/betterpmmp-vendor-patches/raklib-tick-slice.patch"
      }
   },
   "scripts": {
      "test": "@php vendor/bin/phpunit --configuration phpunit.xml.dist",
      "analyse": "@php vendor/bin/phpstan analyse --memory-limit=2G"
   }
}
